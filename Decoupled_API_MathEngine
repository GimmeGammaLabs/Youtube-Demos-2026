def run_real_time_quant_engine(n, ticker, expiration, vol, greek_selection, call_ratio, put_ratio, reset_btn, current_state):
    """
    THE MAIN ENGINE CALLBACK -- fires on every heartbeat tick and user input change.

    Execution flow (in order):
      1. Detect which component triggered this callback (tick vs user control)
      2. Proactively refresh the Schwab access_token if it is about to expire
      3. Instantiate DataPipelineManager and fetch data (Schwab -> Yahoo -> Sim)
      4. Pass raw chain through the vectorized Greek engine (add_greeks_to_df)
      5. Filter the chain by the selected expiration bucket (0DTE, 1-Week, etc)
      6. Compute per-strike aggregated exposure and identify Call/Put Walls
      7. Compute the continuous GEX/VEX/CEX profile and Gamma Flip level
      8. Format all text values for the 6 metric header cards
      9. Build Chart 1: Per-strike bar chart (colored by positive/negative)
      10. Build Chart 2: Continuous profile line chart + 2D concentration heatmap
      11. Return all 22 outputs to Dash for a synchronized single-render update
    """
    # ---- STEP 1: Determine what triggered this callback ----
    # triggered_id is used by SimulatedProvider to decide whether to apply
    # random micro-drift noise (only on auto ticks, not user control changes)
    ctx = dash.callback_context
    triggered_id = ctx.triggered[0]["prop_id"].split(".")[0] if ctx.triggered else ""

    # Fallback spot prices -- shown before any live data arrives on startup
    base_spots = {"SPX": 5350.00, "NDX": 18600.00, "AAPL": 185.00, "NVDA": 135.00}
    current_base = base_spots.get(ticker, 5000.00)
    
    if not current_state or not isinstance(current_state, dict):
        current_state = {"spot": current_base, "prev_spot": current_base}
    
    if triggered_id in ["btn-reset", "dropdown-ticker", "", "."]:
        spot = current_base
        prev_spot = current_base
    else:
        prev_spot = current_state.get("spot", current_base)
        spot = prev_spot
        
    # ---- STEP 2: Proactive token refresh ----
    # Check if the Schwab access_token expires within 60 seconds.
    # If so, use the refresh_token to silently get a new access_token.
    # This prevents mid-session disconnects during live market hours.
    tokens = load_schwab_tokens()
    if tokens.get("access_token") and tokens.get("refresh_token"):
        if time.time() > (tokens.get("expires_at", 0) - 60):
            success, _ = refresh_schwab_access_token(tokens)
            if success:
                tokens = load_schwab_tokens()  # Reload with the freshly issued token

    # ---- STEP 3: Fetch data through the decoupled pipeline ----
    # Instantiate the Math Engine with live Risk-Free Rate and User Dealer Ratios
    market = OptionsMarketSimulator(
        ticker=ticker, 
        spot=spot, 
        vol=vol, 
        rate=get_live_risk_free_rate(), 
        call_ratio=call_ratio, 
        put_ratio=put_ratio
    )
    
    # DataPipelineManager tries each provider in priority order.
    # The math engine below this block is completely unaware of the data source.
    pipeline = DataPipelineManager([
        SchwabProvider(),                        # Priority 1: Live Schwab brokerage data
        YFinanceProvider(),                      # Priority 2: Yahoo Finance (free fallback)
        SimulatedProvider(market, triggered_id)  # Priority 3: Local Monte Carlo simulation
    ])
    spot, raw_chain, source_name = pipeline.fetch_best_data(ticker, spot, vol, tokens=tokens)
    
    # ---- STEP 4: Inject Greeks into the raw chain ----
    # SimulatedProvider already returns a chain WITH Greeks computed.
    # Schwab/Yahoo return raw market data (Strike, IV, OI, DTE) without Greeks.
    # We check for the "GEX" column to avoid redundant double-computation.
    if "GEX" not in raw_chain.columns:
        chain_df = market.add_greeks_to_df(raw_chain, spot)  # Vectorized BS computation
    else:
        chain_df = raw_chain  # Already has Greeks -- simulation path
        
    updated_state = {"spot": spot, "prev_spot": prev_spot}
    
    # ---- STEP 5: Expiration filter + strike aggregation ----
    # Filter to only the selected expiration bucket, or use the full chain.
    # Aggregate GEX per strike to find the Call Wall (max) and Put Wall (min).
    if expiration != "ALL":
        filtered_chain = chain_df[chain_df["Expiration"] == expiration]
    else:
        filtered_chain = chain_df

    # Sum all GEX values at each strike to find liquidity walls
    strike_gex = filtered_chain.groupby("Strike")["GEX"].sum().reset_index()

    # ---- STEP 6: Compute continuous exposure profile and gamma flip ----
    # This produces both the profile curves AND the 2D heatmap matrices
    profile_df, flip_price, unique_strikes, gex_mat, vex_mat, cex_mat = market.compute_exposure_profiles(filtered_chain, spot)

    # Identify Call Wall (highest positive GEX) and Put Wall (most negative GEX)
    if not strike_gex.empty and not strike_gex["GEX"].isna().all():
        call_wall = strike_gex.loc[strike_gex["GEX"].idxmax()]["Strike"]
        put_wall = strike_gex.loc[strike_gex["GEX"].idxmin()]["Strike"]
    else:
        call_wall, put_wall = 0.0, 0.0
    
    # ---- STEP 7: Format metric card values ----
    spot_str = f"${spot:,.2f}"
    # Intraday change = current spot vs. close of previous session (current_base)
    net_day_change = spot - current_base
    pct_day_change = (net_day_change / current_base) * 100.0
    change_sign = "+" if net_day_change >= 0 else ""
    change_color = "text-success" if net_day_change >= 0 else "text-danger"
    change_str = f"{change_sign}${net_day_change:,.2f} ({change_sign}{pct_day_change:.2f}%)"
    
    # 1. Net GEX
    net_gex_val = strike_gex["GEX"].sum() if not strike_gex.empty else 0.0
    net_gex_str = format_exposure(net_gex_val)
    net_gex_class = "text-success" if net_gex_val >= 0 else "text-danger"
    
    # 2. Net VEX
    net_vex_val = filtered_chain["VEX"].sum() if not filtered_chain.empty else 0.0
    net_vex_str = format_exposure(net_vex_val)
    net_vex_class = "text-success" if net_vex_val >= 0 else "text-danger"
    
    # 3. Net CEX
    net_cex_val = filtered_chain["CEX"].sum() if not filtered_chain.empty else 0.0
    net_cex_str = format_exposure(net_cex_val)
    net_cex_class = "text-success" if net_cex_val >= 0 else "text-danger"
    
    # 4. Gamma Flip
    flip_str = f"${flip_price:,.2f}"
    dist_to_flip = ((spot - flip_price) / spot) * 100
    dist_str = f"Spot is {('+' if dist_to_flip >= 0 else '')}{dist_to_flip:.2f}% from Flip"
    dist_color = "text-success" if dist_to_flip >= 0 else "text-danger"
    
    # ---- STEP 8: Determine volatility regime from gamma flip ----
    # Above the flip: Long Gamma (dealers are stabilizing forces)
    # Below the flip: Short Gamma (dealers amplify volatility)
    if spot >= flip_price:
        regime_label = "LONG GAMMA"
        regime_class = "text-success"
        regime_desc = "Dealers support dips / cap rallies. Low volatility."
    else:
        regime_label = "SHORT GAMMA"
        regime_class = "text-danger"
        regime_desc = "Dealers chase price momentum. Tail-risk volatility high."
        
    call_wall_str = f"${call_wall:,.1f}"
    put_wall_str = f"${put_wall:,.1f}"
    
    # ---- STEP 9: Build Chart 1 -- per-strike exposure bar chart ----
