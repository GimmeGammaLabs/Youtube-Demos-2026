# ==============================================================================
# SECTION 5: INTERACTIVE CALLBACK CONTROLLERS
# ==============================================================================
# Callbacks are the reactive core of Dash. Each @app.callback declares:
#   Output  : Which component property to UPDATE when the function runs
#   Input   : Which component property TRIGGERS the function when it changes
#   State   : Which component property to READ passively (no trigger)
#
# The main engine callback fires on EVERY heartbeat tick (dcc.Interval) AND
# whenever the user changes any control (ticker, expiration, vol, greek).
# It returns 22 output values that simultaneously update every metric card
# and both charts in a single synchronous render cycle.
# ==============================================================================
# 3. INTERACTIVE CALLBACK CONTROLLERS
# ==============================================================================

def format_exposure(val):
    """
    Format a raw dollar exposure value into a human-readable abbreviated string.
    Automatically scales to Billions (Bn), Millions (Mn), or Thousands (K).
    Preserves the sign using a string prefix so formatting is culture-agnostic.

    Examples: 2,400,000,000 -> "$2.40 Bn"  |  -560,000 -> "-$560.00 K"
    """
    prefix = "-" if val < 0 else ""
    abs_val = abs(val)
    if abs_val >= 1e9:
        return f"{prefix}${abs_val / 1e9:.2f} Bn"
    elif abs_val >= 1e6:
        return f"{prefix}${abs_val / 1e6:.2f} Mn"
    elif abs_val >= 1e3:
        return f"{prefix}${abs_val / 1e3:.2f} K"
    else:
        return f"{prefix}${abs_val:.2f}"

def map_symbol_to_schwab(ticker):
    """
    Map a generic ticker to the Schwab API symbol format.
    Schwab requires index symbols to be prefixed with $:
      SPX -> $SPX,  NDX -> $NDX
    Equity symbols (AAPL, NVDA) are passed through unchanged.
    """
    if ticker in ["SPX", "NDX"]:
        return f"${ticker}"
    return ticker

