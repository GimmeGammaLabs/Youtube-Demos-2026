class DataProvider:
    """
    Abstract base interface that all data providers must implement.
    Defines the contract: accept a ticker + params, return standardized data.

    Return signature: (spot_price: float, chain_df: pd.DataFrame, source_name: str)
    On failure, return: (None, None, None) to signal cascade to next provider.
    """

class SchwabProvider(DataProvider):
    def fetch_data(self, ticker, current_spot, vol, tokens=None, **kwargs):
        if not tokens or not tokens.get("access_token") or not tokens.get("refresh_token"):
            return None, None, None
            
        if time.time() > tokens.get("expires_at", 0):
            return None, None, None
            
        schwab_symbol = map_symbol_to_schwab(ticker)
        quotes = fetch_schwab_quotes(schwab_symbol, tokens["access_token"])
        spot_schwab = current_spot
        if quotes and schwab_symbol in quotes:
            try:
                quote_data = quotes[schwab_symbol]["quote"]
                spot_schwab = float(quote_data.get("lastPrice", current_spot))
                if spot_schwab == 0:
                    spot_schwab = float(quote_data.get("closePrice", current_spot))
            except Exception:
                pass
                
        schwab_chain = fetch_schwab_chains(schwab_symbol, tokens["access_token"])
        if not schwab_chain:
            return None, None, None
            
        try:
            records = []
            call_map = schwab_chain.get("callExpDateMap", {})
            put_map = schwab_chain.get("putExpDateMap", {})
            
            for exp_key, strikes_dict in call_map.items():
                parts = exp_key.split(':')
                days_to_expiration = int(parts[1]) if len(parts) > 1 else 0
                dte = days_to_expiration / 365.0
                exp_label = "0DTE" if days_to_expiration <= 1 else "1-Week" if days_to_expiration <= 8 else "1-Month" if days_to_expiration <= 35 else "3-Month"
                for strike_str, contracts in strikes_dict.items():
                    for contract in contracts:
                        iv = safe_float(contract.get("volatility", vol), vol)
                        if iv > 2.0: iv /= 100.0
                        elif iv <= 0 or np.isnan(iv): iv = vol
                        strike_val = safe_float(contract.get("strikePrice", strike_str))
                        oi_val = safe_int(contract.get("openInterest", 0))
                        records.append({"Expiration": exp_label, "Strike": strike_val, "Type": "Call", "IV": iv, "OI": oi_val, "DTE": dte})
            
            for exp_key, strikes_dict in put_map.items():
                parts = exp_key.split(':')
                days_to_expiration = int(parts[1]) if len(parts) > 1 else 0
                dte = days_to_expiration / 365.0
                exp_label = "0DTE" if days_to_expiration <= 1 else "1-Week" if days_to_expiration <= 8 else "1-Month" if days_to_expiration <= 35 else "3-Month"
                for strike_str, contracts in strikes_dict.items():
                    for contract in contracts:
                        iv = safe_float(contract.get("volatility", vol), vol)
                        if iv > 2.0: iv /= 100.0
                        elif iv <= 0 or np.isnan(iv): iv = vol
                        strike_val = safe_float(contract.get("strikePrice", strike_str))
                        oi_val = safe_int(contract.get("openInterest", 0))
                        records.append({"Expiration": exp_label, "Strike": strike_val, "Type": "Put", "IV": iv, "OI": oi_val, "DTE": dte})
                        
            if not records:
                return None, None, None
            return spot_schwab, pd.DataFrame(records), "LIVE SCHWAB DATA"
        except Exception:
            return None, None, None

class YFinanceProvider(DataProvider):
    """
    Secondary fallback provider using Yahoo Finance (via the yfinance library).
    Free, publicly accessible, requires zero authentication.

    Key implementation decisions:
      - Index symbols need a ^ prefix for yfinance: SPX -> ^SPX, NDX -> ^NDX
      - We only fetch the first 4 expiration dates to keep response time fast.
        Fetching all 50+ expirations would take 10+ seconds per refresh cycle.
      - Yahoo's impliedVolatility is already in decimal form (0.235 = 23.5%).
        Unlike Schwab, no conversion needed.
      - DTE is computed from the ISO date string returned by yfinance.
      - We floor DTE at 0.5 days (not 0) to prevent division-by-zero in BS math
        when an expiration date is today.
      - If yfinance is unavailable (network error, rate limit), returns None
        which cascades to the SimulatedProvider.
    """
    def fetch_data(self, ticker, current_spot, vol, **kwargs):
        try:
            yf_ticker = f"^{ticker}" if ticker in ["SPX", "NDX"] else ticker
            tk = yf.Ticker(yf_ticker)
            
            spot = current_spot
            try:
                hist = tk.history(period="1d")
                if not hist.empty:
                    spot = float(hist["Close"].iloc[-1])
            except Exception:
                pass
                
            expirations = tk.options
            if not expirations:
                return None, None, None
                
            records = []
            for exp_date in expirations[:4]:
                chain = tk.option_chain(exp_date)
                days = max((datetime.strptime(exp_date, "%Y-%m-%d") - datetime.now()).days, 0)
                dte = max(days, 0.5) / 365.0
                exp_label = "0DTE" if days <= 1 else "1-Week" if days <= 8 else "1-Month" if days <= 35 else "3-Month"
                
                for _, row in chain.calls.iterrows():
                    iv = safe_float(row.get("impliedVolatility", vol), vol)
                    if iv <= 0 or np.isnan(iv): iv = vol
                    strike_val = safe_float(row.get("strike", 0))
                    oi_val = safe_int(row.get("openInterest", 0))
                    records.append({"Expiration": exp_label, "Strike": strike_val, "Type": "Call", "IV": iv, "OI": oi_val, "DTE": dte})
                    
                for _, row in chain.puts.iterrows():
                    iv = safe_float(row.get("impliedVolatility", vol), vol)
                    if iv <= 0 or np.isnan(iv): iv = vol
                    strike_val = safe_float(row.get("strike", 0))
                    oi_val = safe_int(row.get("openInterest", 0))
                    records.append({"Expiration": exp_label, "Strike": strike_val, "Type": "Put", "IV": iv, "OI": oi_val, "DTE": dte})
                    
            if not records:
                return None, None, None
            return spot, pd.DataFrame(records), "YFINANCE DATA"
        except Exception:
            return None, None, None

class SimulatedProvider(DataProvider):
    """
    Tertiary offline fallback -- generates a completely synthetic options chain.
    No internet connection required. Works entirely with local math.

    The micro-drift simulation adds small random-walk noise to the spot price
    on each automatic system-tick to simulate live price movement. This gives
    the dashboard a sense of liveness even with zero API connectivity.

    The synthetic chain uses a realistic volatility smile/skew model and
    clusters open interest at psychological round-number strike levels --
    making the simulation visually believable and educationally meaningful.
    """
    def __init__(self, simulator, triggered_id):
        self.simulator = simulator
        self.triggered_id = triggered_id
        
    def fetch_data(self, ticker, current_spot, vol, **kwargs):
        spot = current_spot
        if self.triggered_id == "system-tick":
            drift = 0.0001 * (np.random.rand() - 0.49) 
            vol_impact = vol * 0.05 * np.random.randn()
            spot = spot * (1.0 + drift + vol_impact)
            
        self.simulator.ticker = ticker
        self.simulator.vol = vol
        chain_df = self.simulator.generate_option_chain(spot)
        return spot, chain_df, "SIMULATED DATA"

class DataPipelineManager:
    """
    Orchestrates the priority cascade through all registered data providers.

    Calls providers[0].fetch_data() first. If it returns a non-empty DataFrame,
    that data is used and remaining providers are never called. If it returns
    (None, None, None), falls through to providers[1], and so on.

    If ALL providers fail (rare edge case), returns an empty DataFrame with
    source_name "ERROR: NO DATA". The callback handles this gracefully by
    displaying stale data rather than crashing the server.
    """
    def __init__(self, providers):
        self.providers = providers
        
    def fetch_best_data(self, ticker, current_spot, vol, **kwargs):
        for provider in self.providers:
            spot, df, name = provider.fetch_data(ticker, current_spot, vol, **kwargs)
            if df is not None and not df.empty:
                return spot, df, name
        return current_spot, pd.DataFrame(), "ERROR: NO DATA"

# ==============================================================================
# SECTION 3: MATHEMATICAL ENGINE AND VECTORIZED BLACK-SCHOLES SOLVER
# ==============================================================================
# This section is the CORE of the program. It is completely decoupled from
# all external APIs and data sources -- it receives a plain DataFrame and
# produces exposure metrics using analytical Black-Scholes formulas.
#
# Black-Scholes Quick Reference:
#   d1 = [ln(S/K) + (r - q + 0.5*sigma^2)*T] / (sigma * sqrt(T))
#   d2 = d1 - sigma * sqrt(T)
#
#   Delta(Call) = exp(-q*T) * N(d1)
#   Delta(Put)  = -exp(-q*T) * N(-d1)
#   Gamma       = exp(-q*T) * n(d1) / (S * sigma * sqrt(T))
#   Vanna       = -exp(-q*T) * n(d1) * d2 / sigma
#   Charm       = dividend*exp(-q*T)*N(d1) - exp(-q*T)*n(d1)*[...]
#
# Where: S=Spot, K=Strike, T=Time(years), r=Rate, q=Dividend, sigma=IV
#        N(x) = Cumulative Normal CDF, n(x) = Normal PDF
# ==============================================================================

# 1. MATHEMATICAL ENGINE & VECTORIZED OPTION GENERATOR
# ==============================================================================

class OptionsMarketSimulator:
    """
    Simulates real-time options chain data and computes dealer Gamma Exposure (GEX),
    Vanna Exposure (VEX), and Charm Exposure (CEX) using institutional-grade 
    Black-Scholes modeling and vol-skew curves.
    """
    def __init__(self, ticker="SPX", spot=5350.0, vol=0.15, rate=0.045, dividend=0.015, call_ratio=0.5, put_ratio=-0.6):
        self.ticker = ticker
        self.spot = spot
        self.vol = vol
        self.rate = rate
        self.dividend = dividend
        self.call_ratio = call_ratio
        self.put_ratio = put_ratio
        self.contract_size = 100
        
    def generate_option_chain(self, current_spot):
        """
        Generates a synthetic options chain with realistic strike clustering,
        volatility smile/skew, and open interest distribution. Appends Vanna and Charm.
        """
        np.random.seed(int(current_spot) % 1000 + 42) # Deterministic yet changing
        
        # Determine strike range around current spot (+/- 10%)
        step = 10 if self.ticker in ["SPX", "NDX"] else 1
        num_strikes = 40
        min_strike = int((current_spot * 0.90) / step) * step
        max_strike = int((current_spot * 1.10) / step) * step
        strikes = np.arange(min_strike, max_strike + step, step)
        
        # Simulate different expirations: 0DTE, 1W, 1M, 3M
        days_to_expiry = [0.004, 0.019, 0.082, 0.25] # In fractions of a year
        exp_labels = ["0DTE", "1-Week", "1-Month", "3-Month"]
        
        records = []
        
        for dte, exp_label in zip(days_to_expiry, exp_labels):
            for strike in strikes:
                # 1. Volatility Smile Model (Skew): Puts have higher implied volatility
                distance = (strike - current_spot) / current_spot
                strike_iv = self.vol + 0.15 * (distance ** 2) - 0.12 * distance
                strike_iv = np.clip(strike_iv, 0.05, 0.60)
                
                # 2. Open Interest distribution (Clustered around psychological levels)
                base_oi = np.exp(-0.5 * (distance / 0.04) ** 2) * 50000
                psy_level = 100 if self.ticker in ["SPX", "NDX"] else 10
                half_psy_level = 50 if self.ticker in ["SPX", "NDX"] else 5
                
                if strike % psy_level == 0:
                    base_oi *= 2.5
                elif strike % half_psy_level == 0:
                    base_oi *= 1.6
                
                # 3. Simulate Total Exposure Size per Strike
                call_oi = np.random.randint(100, 5000)
                put_oi = np.random.randint(100, 5000)
                
                # 4. Generate the Black-Scholes Greeks using the exact same logic
                #    used in the batch engine, but applied point-by-point for the sim
                for opt_type, oi, ratio in [("Call", call_oi, self.call_ratio), ("Put", put_oi, self.put_ratio)]:
                    g, d, vanna, charm = self._black_scholes_greeks(current_spot, strike, dte, strike_iv, opt_type)
                    
                    # Calculate Notional Gamma Exposure (GEX) per 1% underlying move
                    gex = g * self.contract_size * oi * ratio * (current_spot ** 2) * 0.01
                    
                    # Vanna Exposure (VEX): Change in Dollar Delta per 1% absolute point move in IV
                    vex = vanna * self.contract_size * oi * ratio * current_spot * 0.01
                    
                    # Charm Exposure (CEX): Daily Delta decay bleed (scaled to days via / 365)
                    cex = (charm / 365.0) * self.contract_size * oi * ratio * current_spot
                    
                    records.append({
                        "Expiration": exp_label,
                        "Strike": strike,
                        "Type": opt_type,
                        "IV": strike_iv,
                        "OI": oi,
                        "Delta": d,
                        "Gamma": g,
                        "GEX": gex,
                        "Vanna": vanna,
                        "VEX": vex,
                        "Charm": charm,
                        "CEX": cex,
                        "DTE": dte
                    })
                    
        return pd.DataFrame(records)

    def _black_scholes_greeks(self, S, K, T, v, opt_type):
        """
        Scalar analytical Black-Scholes solver for a single option contract.
        Used internally by generate_option_chain() for the simulated chain.
        (The vectorized batch version for real data is add_greeks_to_df.)

        Parameters:
            S        : Spot price of the underlying asset
            K        : Strike price of the option
            T        : Time to expiration in YEARS (e.g. 1 day = 1/365 = 0.00274)
            v        : Implied volatility as decimal (e.g. 0.20 for 20% IV)
            opt_type : "Call" or "Put"

        Returns: (gamma, delta, vanna, charm)

        Edge case handling:
            T <= 0: Option expired. Return intrinsic delta (1.0, -1.0, or 0.0).
            v < 1e-5: Clamp to avoid division-by-zero in the d1 formula.
        """
        if T <= 0:
            if opt_type == "Call":
                return 0.0, (1.0 if S >= K else 0.0), 0.0, 0.0
            else:
                return 0.0, (-1.0 if S < K else 0.0), 0.0, 0.0
                
        v = max(v, 1e-5)
        sqrt_T = np.sqrt(T)
        d1 = (np.log(S / K) + (self.rate - self.dividend + 0.5 * v ** 2) * T) / (v * sqrt_T)
        d2 = d1 - v * sqrt_T
        
        n_d1 = np.exp(-d1 ** 2 / 2) / np.sqrt(2 * np.pi)
        
        # Gamma (identical for Call and Put)
        gamma = (np.exp(-self.dividend * T) * n_d1) / (S * v * sqrt_T)
        
        # Vanna (dVega/dSpot or dDelta/dVol)
        vanna = -np.exp(-self.dividend * T) * n_d1 * d2 / v
        
        # Charm (dDelta/dT - passage of time derivative)
        charm_common = n_d1 * ((self.rate - self.dividend) / (v * sqrt_T) - d2 / (2 * T))
        if opt_type == "Call":
            delta = np.exp(-self.dividend * T) * ndtr(d1)
            charm = self.dividend * np.exp(-self.dividend * T) * ndtr(d1) - np.exp(-self.dividend * T) * charm_common
        else:
            delta = -np.exp(-self.dividend * T) * ndtr(-d1)
            charm = -self.dividend * np.exp(-self.dividend * T) * ndtr(-d1) - np.exp(-self.dividend * T) * charm_common
            
        return gamma, delta, vanna, charm

    def add_greeks_to_df(self, df, current_spot):
        """
        Vectorized batch Greek engine for processing real market data at speed.

        Instead of calling _black_scholes_greeks() once per row (which is slow),
        this function uses NumPy broadcasting to compute ALL contracts at once.
        This is the critical path that makes the 3-second refresh interval possible.

        Expected input columns: Strike, DTE, IV, OI, Type ("Call" or "Put")

        Exposure formulas:
            GEX = Gamma * ContractSize * OI * DealerRatio * Spot^2 * 0.01
                  Interpretation: dollars of delta-hedge flow per 1% spot move

            VEX = Vanna * ContractSize * OI * DealerRatio * Spot * 0.01
                  Interpretation: dollars of delta change per 1% absolute IV shift

            CEX = (Charm / 365) * ContractSize * OI * DealerRatio * Spot
                  Interpretation: dollars of passive daily delta decay (time bleed)

        Dealer Position Assumptions (standard GEX convention):
            Calls: dealers are net SHORT -> ratio = +0.5 -> positive GEX
            Puts:  dealers are net LONG  -> ratio = -0.6 -> negative GEX
        """
        if df.empty:
            return df
            
        S = current_spot
        K = df["Strike"].values
        T = df["DTE"].values
        v = df["IV"].values
        OI = df["OI"].values
        opt_types = df["Type"].values
        
        # Ensure T > 0 and v > 0 to avoid division by zero
        T_safe = np.where(T <= 0, 1e-5, T)
        v_safe = np.where(v <= 0, 1e-5, v)
        sqrt_T = np.sqrt(T_safe)
        
        d1 = (np.log(S / K) + (self.rate - self.dividend + 0.5 * v_safe ** 2) * T_safe) / (v_safe * sqrt_T)
        d2 = d1 - v_safe * sqrt_T
        n_d1 = np.exp(-d1 ** 2 / 2) / np.sqrt(2 * np.pi)
        
        # Gamma
        gamma = (np.exp(-self.dividend * T_safe) * n_d1) / (S * v_safe * sqrt_T)
        
        # Vanna
        vanna = -np.exp(-self.dividend * T_safe) * n_d1 * d2 / v_safe
        
        # Charm
        charm_common = n_d1 * ((self.rate - self.dividend) / (v_safe * sqrt_T) - d2 / (2 * T_safe))
        ndtr_d1 = ndtr(d1)
        
        charm_call = self.dividend * np.exp(-self.dividend * T_safe) * ndtr_d1 - np.exp(-self.dividend * T_safe) * charm_common
        charm_put = -self.dividend * np.exp(-self.dividend * T_safe) * (1.0 - ndtr_d1) - np.exp(-self.dividend * T_safe) * charm_common
        charm = np.where(opt_types == "Call", charm_call, charm_put)
        
        # Delta
        delta_call = np.exp(-self.dividend * T_safe) * ndtr_d1
        delta_put = -np.exp(-self.dividend * T_safe) * (1.0 - ndtr_d1)
        delta = np.where(opt_types == "Call", delta_call, delta_put)
        
        # Dealer ratios
        ratios = np.where(opt_types == "Call", 0.5, -0.6)
        
        # Exposures
        gex = gamma * self.contract_size * OI * ratios * (S ** 2) * 0.01
        vex = vanna * self.contract_size * OI * ratios * S * 0.01
        cex = (charm / 365.0) * self.contract_size * OI * ratios * S
        
        df["Delta"] = delta
        df["Gamma"] = gamma
        df["GEX"] = gex
        df["Vanna"] = vanna
        df["VEX"] = vex
        df["Charm"] = charm
        df["CEX"] = cex
        
        return df

    def compute_exposure_profiles(self, chain_df, current_spot, price_range_pct=0.10, steps=50):
        """
        Sweeps the underlying price across a range and computes total exposure at each level.

        This is the most computationally intensive function. It builds a 2D matrix
        of shape (50 price steps x N contracts) using NumPy broadcasting, computing
        each contract's Greek contribution at every price level simultaneously.

        Returns:
            profile_df     : DataFrame(UnderlyingPrice, NetGEX, NetVEX, NetCEX)
                             The summed exposure at each price point -- drives the
                             continuous profile line chart (top panel).

            flip_price     : The interpolated zero-crossing of NetGEX.
                             Found using sign-change detection (np.sign + np.diff)
                             with linear interpolation for sub-grid precision.

            unique_strikes  : Sorted array of unique strike prices (heatmap y-axis)

            gex/vex/cex_mat : 2D matrices [price_steps x unique_strikes]
                              Each cell = that strike's exposure at that price.
                              Transposed (.T) before passing to go.Heatmap.
        """
        if chain_df.empty:
            return pd.DataFrame(columns=["UnderlyingPrice", "NetGEX", "NetVEX", "NetCEX"]), current_spot, np.array([]), np.zeros((steps, 0)), np.zeros((steps, 0)), np.zeros((steps, 0))

        min_price = current_spot * (1.0 - price_range_pct)
        max_price = current_spot * (1.0 + price_range_pct)
        
        P = np.linspace(min_price, max_price, steps).reshape(-1, 1)
        K = chain_df["Strike"].values.reshape(1, -1)
        T = chain_df["DTE"].values.reshape(1, -1)
        V = chain_df["IV"].values.reshape(1, -1)
        OI = chain_df["OI"].values.reshape(1, -1)
        ratios = np.where(chain_df["Type"] == "Call", self.call_ratio, self.put_ratio).reshape(1, -1)
        is_call = (chain_df["Type"] == "Call").values.reshape(1, -1)
        
        T = np.where(T <= 0, 1e-5, T)
        V = np.where(V <= 0, 1e-5, V)

        # BS calculations
        d1 = (np.log(P / K) + (self.rate - self.dividend + 0.5 * V ** 2) * T) / (V * np.sqrt(T))
        d2 = d1 - V * np.sqrt(T)
        n_d1 = np.exp(-d1 ** 2 / 2) / np.sqrt(2 * np.pi)
        
        # 1. Gamma & GEX
        gamma = (np.exp(-self.dividend * T) * n_d1) / (P * V * np.sqrt(T))
        gex_matrix = gamma * self.contract_size * OI * ratios * (P ** 2) * 0.01
        net_gex_profile = np.sum(gex_matrix, axis=1)
        
        # 2. Vanna & VEX
        vanna = -np.exp(-self.dividend * T) * n_d1 * d2 / V
        vex_matrix = vanna * self.contract_size * OI * ratios * P * 0.01
        net_vex_profile = np.sum(vex_matrix, axis=1)
        
        # 3. Charm & CEX
        charm_common = n_d1 * ((self.rate - self.dividend) / (V * np.sqrt(T)) - d2 / (2 * T))
        ndtr_d1 = ndtr(d1)
        charm = np.where(
            is_call,
            self.dividend * np.exp(-self.dividend * T) * ndtr_d1 - np.exp(-self.dividend * T) * charm_common,
            -self.dividend * np.exp(-self.dividend * T) * (1.0 - ndtr_d1) - np.exp(-self.dividend * T) * charm_common
        )
        cex_matrix = (charm / 365.0) * self.contract_size * OI * ratios * P
        net_cex_profile = np.sum(cex_matrix, axis=1)

        # Group exposure matrices by unique strike prices
        strikes_arr = chain_df["Strike"].values
        unique_strikes = np.unique(strikes_arr)
        
        gex_strike_matrix = np.zeros((steps, len(unique_strikes)))
        vex_strike_matrix = np.zeros((steps, len(unique_strikes)))
        cex_strike_matrix = np.zeros((steps, len(unique_strikes)))
        
        for idx, strike in enumerate(unique_strikes):
            mask = (strikes_arr == strike)
            gex_strike_matrix[:, idx] = np.sum(gex_matrix[:, mask], axis=1)
            vex_strike_matrix[:, idx] = np.sum(vex_matrix[:, mask], axis=1)
            cex_strike_matrix[:, idx] = np.sum(cex_matrix[:, mask], axis=1)

        profile_df = pd.DataFrame({
            "UnderlyingPrice": P.flatten(),
            "NetGEX": net_gex_profile,
            "NetVEX": net_vex_profile,
            "NetCEX": net_cex_profile
        })
        
        flip_price = current_spot
        try:
            # Check if there is a sign crossing
            if np.sign(net_gex_profile.max()) != np.sign(net_gex_profile.min()):
                # Create a highly precise mathematical spline representation of the NetGEX curve
                # Smoothing factor s=0 ensures it passes exactly through our points
                spline = UnivariateSpline(profile_df["UnderlyingPrice"], profile_df["NetGEX"], s=0)
                
                # Find the roots (zero-crossings) of the spline function
                roots = spline.roots()
                
                if len(roots) > 0:
                    # If multiple roots exist, pick the one closest to the current spot price
                    flip_price = roots[np.abs(roots - current_spot).argmin()]
        except Exception:
            pass
            
        return profile_df, flip_price, unique_strikes, gex_strike_matrix, vex_strike_matrix, cex_strike_matrix

