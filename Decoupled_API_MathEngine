            fig_profile.add_vline(x=call_wall, line_width=1.5, line_dash="dash", line_color="#ef4444", row=r, col=1)
        if put_wall:
            fig_profile.add_vline(x=put_wall, line_width=1.5, line_dash="dash", line_color="#22c55e", row=r, col=1)
    
    # Update subplot titles style
    for annot in fig_profile['layout']['annotations']:
        annot['font'] = dict(color="#8a92a6", size=11)
    
    schwab_badge_text = source_name
    schwab_badge_class = "badge bg-success ms-auto live-badge-pulse" if source_name == "LIVE SCHWAB DATA" else "badge bg-info ms-auto" if source_name == "YFINANCE DATA" else "badge bg-secondary ms-auto"
    
    return (
        updated_state, spot_str, change_str, change_color,
        net_gex_str, net_gex_class, net_vex_str, net_vex_class, net_cex_str, net_cex_class,
        flip_str, dist_str, dist_color, regime_label, regime_class, regime_desc,
        call_wall_str, flip_str, put_wall_str, fig_strikes, fig_profile,
        schwab_badge_text, schwab_badge_class
    )

