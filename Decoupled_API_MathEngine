# Path to the local JSON file that persists tokens between app sessions
TOKEN_FILE = "schwab_tokens.json"

def load_schwab_tokens():
    """
    Load OAuth tokens and credentials from the local JSON file.

    If the file does not exist yet, returns a safe default dict with DUMMY
    placeholder strings so the app runs without crashing. The merge loop
    ensures any new keys added in future versions are always present even
    if the saved file is from an older version.
    """
    default_tokens = {
        "app_key": "DUMMY_SCHWAB_APP_KEY",
        "app_secret": "DUMMY_SCHWAB_APP_SECRET",
        "redirect_uri": "https://127.0.0.1",
        "access_token": "",
        "refresh_token": "",
        "expires_at": 0,
        "refresh_expires_at": 0
    }
    if os.path.exists(TOKEN_FILE):
        try:
            with open(TOKEN_FILE, "r") as f:
                data = json.load(f)
                # Merge with default_tokens to ensure all keys exist
                for k, v in default_tokens.items():
                    if k not in data:
                        data[k] = v
                return data
        except Exception:
            return default_tokens
    return default_tokens

def save_schwab_tokens(tokens):
    """
    Persist the full token/credential dictionary to schwab_tokens.json.
    Uses indent=4 for human-readable formatting in case you need to inspect it.
    Returns True on success, False if the write fails (e.g., permissions issue).
    """
    try:
        with open(TOKEN_FILE, "w") as f:
            json.dump(tokens, f, indent=4)
        return True
    except Exception:
        return False

def exchange_schwab_auth_code(code, tokens):
    """
    OAuth Token Exchange: Swap a one-time authorization code for long-lived tokens.

    Schwab's token endpoint uses HTTP Basic Auth where the Authorization header
    contains "Basic " + base64(AppKey + ":" + AppSecret).

    The 'code' argument can be EITHER:
      - The raw code string (e.g. "C0abc123...")
      - The full redirect URL pasted from the browser address bar
    Both cases are handled -- we parse the URL and extract the ?code= param if
    a "code=" substring is detected in the input.
    """
    app_key = tokens.get("app_key")
    app_secret = tokens.get("app_secret")
    redirect_uri = tokens.get("redirect_uri")
    
    if not app_key or not app_secret or "DUMMY" in app_key or "DUMMY" in app_secret:
        return False, "Invalid App Key or App Secret"
        
    url = "https://api.schwabapi.com/v1/oauth/token"
    
    # Base64 encode app_key:app_secret
    credentials = f"{app_key}:{app_secret}"
    encoded_creds = base64.b64encode(credentials.encode()).decode()
    
    headers = {
        "Authorization": f"Basic {encoded_creds}",
        "Content-Type": "application/x-www-form-urlencoded"
    }
    
    # If the code was pasted as a full URL, parse it
    if "code=" in code:
        try:
            parsed = urllib.parse.urlparse(code)
            params = urllib.parse.parse_qs(parsed.query)
            code = params.get("code", [code])[0]
        except Exception:
            pass
            
    payload = {
        "grant_type": "authorization_code",
        "code": code,
        "redirect_uri": redirect_uri
    }
    
    try:
        response = requests.post(url, headers=headers, data=payload, timeout=10)
        if response.status_code == 200:
            res_data = response.json()
            tokens["access_token"] = res_data.get("access_token")
            tokens["refresh_token"] = res_data.get("refresh_token")
            tokens["expires_at"] = time.time() + float(res_data.get("expires_in", 1800))
            tokens["refresh_expires_at"] = time.time() + float(res_data.get("refresh_token_expires_in", 604800))
            save_schwab_tokens(tokens)
            return True, "Successfully connected to Schwab Live Data!"
        else:
            return False, f"Failed: {response.status_code} - {response.text}"
    except Exception as e:
        return False, f"Error: {str(e)}"

def refresh_schwab_access_token(tokens):
    """
    Silently re-issue a new access_token using the stored refresh_token.

    Called automatically on every dashboard tick when the current access_token
    is within 60 seconds of its expiry (expires_at - 60). This prevents
    mid-session disconnects during live trading hours.

    Schwab sometimes rotates the refresh_token itself -- if the response
    includes a new refresh_token we save it immediately so the session
    can continue for another 7 days without requiring a full re-authorization.

    Returns: (True, success_message) or (False, error_string)
    """
    app_key = tokens.get("app_key")
    app_secret = tokens.get("app_secret")
    refresh_token = tokens.get("refresh_token")
    
    if not app_key or not app_secret or not refresh_token:
        return False, "Missing credentials or refresh token"
        
    url = "https://api.schwabapi.com/v1/oauth/token"
    credentials = f"{app_key}:{app_secret}"
    encoded_creds = base64.b64encode(credentials.encode()).decode()
    
    headers = {
        "Authorization": f"Basic {encoded_creds}",
        "Content-Type": "application/x-www-form-urlencoded"
    }
    
    payload = {
        "grant_type": "refresh_token",
        "refresh_token": refresh_token
    }
    
    try:
        response = requests.post(url, headers=headers, data=payload, timeout=10)
        if response.status_code == 200:
            res_data = response.json()
            tokens["access_token"] = res_data.get("access_token")
            if res_data.get("refresh_token"):
                tokens["refresh_token"] = res_data.get("refresh_token")
            tokens["expires_at"] = time.time() + float(res_data.get("expires_in", 1800))
            save_schwab_tokens(tokens)
            return True, "Token refreshed successfully"
        else:
            return False, f"Failed to refresh: {response.status_code} - {response.text}"
    except Exception as e:
        return False, f"Refresh error: {str(e)}"

def fetch_schwab_quotes(symbols, access_token):
    """
    Fetch a real-time Level 1 quote from Schwab's Market Data API.

    Important symbol formatting rules:
      - Index symbols (SPX, NDX) MUST be prefixed with $: "$SPX", "$NDX"
      - Equity symbols (AAPL, NVDA) are passed as-is
    We handle this mapping in map_symbol_to_schwab() before calling here.

    The 'fields=quote' parameter requests only the quote data object, which
    contains lastPrice, closePrice, and other Level 1 tick fields.

    Returns: parsed JSON dict on success, None on any HTTP or network error.
    """
    url = "https://api.schwabapi.com/marketdata/v1/quotes"
    headers = {
        "Authorization": f"Bearer {access_token}"
    }
    params = {
        "symbols": symbols,
        "fields": "quote"
    }
    try:
        response = requests.get(url, headers=headers, params=params, timeout=10)
        if response.status_code == 200:
            return response.json()
        else:
            return None
    except Exception:
        return None

def fetch_schwab_chains(symbol, access_token):
    """
    Fetch the complete options chain for a symbol from Schwab's /chains endpoint.

    The response format is a nested dictionary:
        callExpDateMap -> { "YYYY-MM-DD:DTE" -> { "strikePrice" -> [contractData] } }
        putExpDateMap  -> (same structure for puts)

    Key parameters used:
      - contractType=ALL  : Returns both calls and puts in a single request
      - includeUnderlyingQuote=true : Embeds the current spot price in the response

    The SchwabProvider class is responsible for flattening this nested structure
    into the standardized flat DataFrame the math engine expects.

    Returns: parsed JSON dict on success, None on any HTTP or network error.
    """
    url = "https://api.schwabapi.com/marketdata/v1/chains"
    headers = {
        "Authorization": f"Bearer {access_token}"
    }
    params = {
        "symbol": symbol,
        "contractType": "ALL",
        "includeUnderlyingQuote": "true"
    }
    try:
        response = requests.get(url, headers=headers, params=params, timeout=10)
        if response.status_code == 200:
            return response.json()
        else:
            return None
    except Exception:
        return None

# ==============================================================================
# SECTION 2: DECOUPLED DATA PIPELINE PROVIDERS (STRATEGY PATTERN)
# ==============================================================================
# The key architectural insight of this program:
#   The mathematical engine should NEVER know where the data came from.
#   Whether it is Schwab live data, Yahoo Finance, or a Monte Carlo simulation,
#   the math always receives the exact same standardized DataFrame format.
#
# This is the SOFTWARE ENGINEERING concept of "Dependency Inversion" --
# high-level modules (math engine, dashboard) don't depend on low-level details
# (specific APIs), they both depend on a shared abstraction (DataProvider).
#
# FALLBACK CASCADE ORDER (tried in sequence until one succeeds):
#   Priority 1: SchwabProvider    -- Real-time authenticated brokerage data
#   Priority 2: YFinanceProvider  -- Free Yahoo Finance data (no auth needed)
#   Priority 3: SimulatedProvider -- Local Monte Carlo synthetic data (offline)
#
# TO ADD A NEW DATA SOURCE (e.g., IBKR, TastyTrade, Polygon.io):
#   1. Create a class inheriting from DataProvider
#   2. Implement fetch_data() to return (spot_float, chain_df, source_name_str)
#   3. Return (None, None, None) to indicate failure and trigger cascade
#   4. Add an instance to the DataPipelineManager providers list in the callback
# ==============================================================================

def safe_float(val, default=0.0):
    """Safely cast a value to float, handling NaNs and None without throwing an exception."""
    try:
        return float(val) if pd.notna(val) else default
    except (ValueError, TypeError):
        return default

def safe_int(val, default=0):
    """Safely cast a value to int, handling NaNs and None without throwing an exception."""
    try:
        return int(float(val)) if pd.notna(val) else default
    except (ValueError, TypeError):
        return default

