# SECTION 6: SCHWAB API DESK CALLBACKS
# ==============================================================================
# These callbacks power the credential input panel. They are separate from the
# main engine callback because they only fire on explicit user button clicks,
# not on the automatic tick interval.
#
# load_initial_credentials : Pre-fills the input boxes from the saved JSON file
# save_credentials         : Writes the user-entered keys to schwab_tokens.json
# generate_schwab_auth_link: Builds and displays the clickable OAuth URL
# connect_schwab_live      : Completes the OAuth handshake (code -> tokens)
# ==============================================================================
# SCHWAB INTERACTIVE CALLBACK CONTROLLERS
# ==============================================================================

@app.callback(
    [
        Output("schwab-app-key", "value"),
        Output("schwab-app-secret", "value"),
        Output("schwab-redirect-uri", "value")
    ],
    [Input("btn-reset", "n_clicks")]
)
def load_initial_credentials(n):
    """
    Pre-populate the credential input boxes from the saved schwab_tokens.json.
    Fires once on page load (triggered by btn-reset with n_clicks=None).
    """
    tokens = load_schwab_tokens()
    return tokens.get("app_key", ""), tokens.get("app_secret", ""), tokens.get("redirect_uri", "")

@app.callback(
    Output("schwab-status-message", "children", allow_duplicate=True),
    Input("schwab-btn-save-keys", "n_clicks"),
    [
        State("schwab-app-key", "value"),
        State("schwab-app-secret", "value"),
        State("schwab-redirect-uri", "value")
    ],
    prevent_initial_call=True
)
def save_credentials(n_clicks, app_key, app_secret, redirect_uri):
    """
    Persist the user-entered API credentials to schwab_tokens.json.
    Strips whitespace from all fields to prevent subtle auth errors.
    The redirect_uri defaults to https://127.0.0.1 if left blank.
    """
    if not n_clicks:
        return ""
    tokens = load_schwab_tokens()
    tokens["app_key"] = app_key.strip() if app_key else ""
    tokens["app_secret"] = app_secret.strip() if app_secret else ""
    tokens["redirect_uri"] = redirect_uri.strip() if redirect_uri else "https://127.0.0.1"
    save_schwab_tokens(tokens)
    return "Credentials saved successfully to schwab_tokens.json!"

@app.callback(
    Output("schwab-auth-link-container", "children"),
    Input("schwab-btn-gen-link", "n_clicks"),
    [
        State("schwab-app-key", "value"),
        State("schwab-redirect-uri", "value")
    ],
    prevent_initial_call=True
)
def generate_schwab_auth_link(n_clicks, app_key, redirect_uri):
    """
    Build the Schwab OAuth authorization URL and render it as a clickable link.
    The user visits this URL, logs into Schwab, grants access, and is redirected
    to https://127.0.0.1/?code=XXX which they then paste back into the dashboard.
    The redirect_uri must be URL-encoded to avoid breaking the query string.
    """
    if not n_clicks:
        return ""
    if not app_key or "DUMMY" in app_key:
        return html.Span("Please enter a valid App Key first!", className="text-danger")
    
    encoded_redirect = urllib.parse.quote(redirect_uri, safe="")
    auth_url = f"https://api.schwabapi.com/v1/oauth/authorize?client_id={app_key}&redirect_uri={encoded_redirect}&response_type=code"
    
    return html.A("👉 CLICK HERE TO AUTHORIZE WITH SCHWAB 👈", href=auth_url, target="_blank", className="text-warning font-weight-bold")

@app.callback(
    Output("schwab-status-message", "children"),
    Input("schwab-btn-connect", "n_clicks"),
    [
        State("schwab-auth-code-input", "value"),
        State("schwab-app-key", "value"),
        State("schwab-app-secret", "value"),
        State("schwab-redirect-uri", "value")
    ],
    prevent_initial_call=True
)
def connect_schwab_live(n_clicks, code, app_key, app_secret, redirect_uri):
    """
    Complete the OAuth 2.0 token exchange: convert the authorization code to tokens.

    The 'code' input can be EITHER:
      - The full redirect URL pasted from the browser address bar
        (e.g. "https://127.0.0.1/?code=C0abc...")
      - Just the raw code string itself
    exchange_schwab_auth_code() handles both cases internally.

    On success, tokens are written to schwab_tokens.json. The main engine
    callback will automatically detect and use them on the next heartbeat tick.
    """
    if not n_clicks:
        return ""
    if not code:
        return "Please paste the redirect URL or code first!"
        
    tokens = {
        "app_key": app_key.strip() if app_key else "",
        "app_secret": app_secret.strip() if app_secret else "",
        "redirect_uri": redirect_uri.strip() if redirect_uri else "https://127.0.0.1",
        "access_token": "",
        "refresh_token": "",
        "expires_at": 0,
        "refresh_expires_at": 0
    }
    
    success, msg = exchange_schwab_auth_code(code.strip(), tokens)
    if success:
        return html.Span(msg, className="text-success")
    else:
        return html.Span(msg, className="text-danger")

